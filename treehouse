<script>
  const heartsContainer = document.getElementById('hearts');
  ['💜','🌸','✨','💕','🌷'].forEach((h, i) => {
    for (let j = 0; j < 4; j++) {
      const el = document.createElement('div');
      el.className = 'heart';
      el.textContent = h;
      el.style.cssText = `left:${Math.random()*100}vw; font-size:${0.9+Math.random()*1.1}rem; animation-duration:${14+Math.random()*14}s; animation-delay:${Math.random()*20}s;`;
      heartsContainer.appendChild(el);
    }
  });

  function scrollContact() { document.getElementById('contact').scrollIntoView({ behavior: 'smooth' }); }

  function handleSubmit() {
    const btn = document.querySelector('.btn-submit');
    btn.textContent = '✅ გაიგზავნა! მალე დაგიკავშირდებით 💜';
    btn.style.cssText = 'background:#5CB85C; color:white; width:100%; padding:14px; border-radius:50px; font-weight:800; font-size:0.98rem; border:none;';
  }

  const obs = new IntersectionObserver(es => es.forEach(e => {
    if (e.isIntersecting) { e.target.style.opacity='1'; e.target.style.transform='translateY(0)'; }
  }), { threshold: 0.1 });
  document.querySelectorAll('.card, .feature-card, .sizes-table').forEach(el => {
    el.style.opacity='0'; el.style.transform='translateY(24px)'; el.style.transition='opacity 0.55s ease, transform 0.55s ease';
    obs.observe(el);
  });
</script>
